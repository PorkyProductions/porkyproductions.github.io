---
interface Props {
	name: string;
	description: string;
	tags: string[];
	liveUrl?: string;
	npmUrl?: string;
	githubUrl?: string;
	index?: number;
}

const { name, description, tags, liveUrl, npmUrl, githubUrl, index = 0 } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<div class="brutal-card project-card-inner">
	<div class="pc-number">{num}</div>
	<h3 class="pc-name">{name}</h3>
	<p class="pc-desc">{description}</p>
	<div class="pc-tags">
		{tags.map(tag => (
			<span class="pc-tag">{tag}</span>
		))}
	</div>
	<div class="pc-links">
		{liveUrl && (
			<a href={liveUrl} target="_blank" rel="noopener noreferrer" class="pc-link pc-link--primary">
				LIVE ↗
			</a>
		)}
		{npmUrl && (
			<a href={npmUrl} target="_blank" rel="noopener noreferrer" class="pc-link pc-link--accent">
				NPM ↗
			</a>
		)}
		{githubUrl && (
			<a href={githubUrl} target="_blank" rel="noopener noreferrer" class="pc-link pc-link--ghost">
				GITHUB ↗
			</a>
		)}
	</div>
</div>

<style>
	.project-card-inner {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.pc-number {
		font-family: 'Courier New', monospace;
		font-size: 0.62rem;
		letter-spacing: 0.2em;
		color: var(--primary);
		margin-bottom: 0.75rem;
	}

	.pc-name {
		font-family: 'Raleway', sans-serif;
		font-weight: 800;
		font-size: 1.25rem;
		color: var(--text);
		margin: 0 0 0.75rem;
		line-height: 1.2;
	}

	.pc-desc {
		font-family: 'Poppins', sans-serif;
		font-size: 0.875rem;
		line-height: 1.75;
		color: var(--text-muted);
		flex-grow: 1;
		margin: 0 0 1.25rem;
	}

	.pc-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 1.25rem;
	}

	.pc-tag {
		font-family: 'Poppins', sans-serif;
		font-size: 0.6rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--primary);
		border: 1px solid rgba(0, 0, 244, 0.3);
		padding: 3px 8px;
	}

	.pc-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.pc-link {
		font-family: 'Poppins', sans-serif;
		font-size: 0.62rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		text-decoration: none;
		padding: 6px 12px;
		border: 1px solid;
		transition: background 0.1s, color 0.1s;
	}

	.pc-link--primary {
		border-color: var(--primary);
		color: var(--primary);
	}
	.pc-link--primary:hover {
		background: var(--primary);
		color: #fff;
	}

	.pc-link--accent {
		border-color: var(--accent);
		color: var(--accent);
	}
	.pc-link--accent:hover {
		background: var(--accent);
		color: #fff;
	}

	.pc-link--ghost {
		border-color: var(--text-muted);
		color: var(--text-muted);
	}
	.pc-link--ghost:hover {
		border-color: var(--text);
		color: var(--text);
	}
</style>
