---
const footerWord = 'PorkyProductions';
const footerChars = [...footerWord];
---

<footer class="site-footer">
	<div class="footer-top">
		<div class="footer-col">
			<div class="footer-brand">
				<img src="/images/HedgehogIcon.png" alt="" class="footer-brand-icon" />
				<div class="footer-wordmark" data-footer-word aria-hidden="true">
					{footerChars.map((char, index) => (
						<span class="footer-word-char" data-char={char} data-index={index}>{char}</span>
					))}
				</div>
				<span class="visually-hidden">{footerWord}</span>
			</div>
			<p class="footer-tagline"><br />Est. 2017 in Philadelphia PA.</p>
		</div>

		<div class="footer-col">
			<p class="footer-heading">CONTACT</p>
			<a href="mailto:tristankenshin@gmail.com" class="footer-link">Tristan</a>
			<a href="mailto:rpmullin17@gmail.com" class="footer-link">Ryan</a>
		</div>

		<div class="footer-col">
			<p class="footer-heading">ISSUES</p>
			<a
				href="https://github.com/PorkyProductions/porkyproductions.github.io/issues"
				class="footer-link"
				target="_blank"
				rel="noopener noreferrer"
			>
				Report on GitHub
			</a>
		</div>

		<div class="footer-col">
			<p class="footer-heading">SOCIALS</p>
			<p class="footer-none">—</p>
		</div>
	</div>

	<div class="footer-bottom">
		<span class="footer-copy">PORKYPRODUCTIONS</span>
		<div class="footer-heart-wrap">
			<span class="footer-made">MADE WITH</span>
			<button id="heart-btn" class="heart-btn" aria-label="Heart">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" id="heart-svg">
					<path d="m8 2.748-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.281 8.717 2.01L8 2.748z"/>
				</svg>
			</button>
			<span class="footer-made">AT PORKYPRODUCTIONS</span>
		</div>
	</div>
</footer>

<script>
	const sounds = [
		'/audio/audio_Air_Woosh_Underwater.mp3',
		'/audio/audio_Alarm_Clock.mp3',
		'/audio/audio_Beep_Short.mp3',
		'/audio/audio_Big_Explosion_Distant.mp3',
		'/audio/audio_Cartoon_Boing.mp3',
		'/audio/audio_Crash.mp3',
		'/audio/audio_Glass_Crunch.mp3',
		'/audio/audio_Glass_Shatters_Into_Debris.mp3',
	];

	let heartCount = 0;
	const heartBtn = document.getElementById('heart-btn');
	const heartSvg = document.getElementById('heart-svg');
	const play = (src: string) => new Audio(src).play().catch(() => {});

	heartBtn?.addEventListener('click', () => {
		heartCount++;
		if (heartSvg) {
			heartSvg.style.transform = 'scale(1.5)';
			setTimeout(() => { heartSvg.style.transform = 'scale(1)'; }, 120);
		}
		if (heartCount <= 8) {
			play(sounds[heartCount - 1]);
		} else if (heartCount === 9) {
			alert('Are you sure you want to keep clicking?');
		} else {
			sounds.forEach(s => play(s));
		}
	});

	const animatedWord = document.querySelector<HTMLElement>('[data-footer-word]');
	const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

	if (animatedWord && !reducedMotion.matches) {
		const chars = Array.from(animatedWord.querySelectorAll<HTMLElement>('.footer-word-char'));
		const targets = chars.map(char => char.dataset.char ?? '');
		const glyphs = '[]{}<>!?*+-_=/\\|';

		let previousTime = performance.now();
		let phase = 0;

		const animateWord = (time: number) => {
			const dt = Math.min(40, time - previousTime);
			previousTime = time;
			phase += dt * 0.0023;

			const sweep = ((phase * 3.2) % (chars.length + 8)) - 4;

			chars.forEach((char, index) => {
				const distance = Math.abs(index - sweep);
				const wave = Math.max(0, 1 - distance / 3.2);
				const orbit = Math.sin(phase * 2.5 + index * 0.68);
				const driftY = orbit * wave * 3.3;
				const driftX = Math.cos(phase * 1.6 + index * 0.55) * wave * 1.2;
				const skew = orbit * wave * 8;
				const scrambleChance = wave < 0.35 ? (0.18 - wave * 0.36) : 0.02;
				const displayChar = Math.random() < scrambleChance
					? glyphs[(Math.random() * glyphs.length) | 0]
					: targets[index];
				const glow = 0.12 + wave * 0.88;
				const accent = (Math.sin(phase * 3.1 + index * 0.7) + 1) * 0.5;

				if (char.textContent !== displayChar) {
					char.textContent = displayChar;
				}

				char.style.transform = `translate(${driftX.toFixed(2)}px, ${driftY.toFixed(2)}px) skewX(${skew.toFixed(2)}deg)`;
				char.style.opacity = `${0.45 + glow * 0.55}`;
				char.style.textShadow = `0 0 ${2 + glow * 8}px rgba(95,125,255,${0.2 + glow * 0.5}), 0 0 ${2 + wave * 11}px rgba(255,77,128,${accent * wave * 0.45})`;
			});

			requestAnimationFrame(animateWord);
		};

		requestAnimationFrame(animateWord);
	}
</script>

<style>
	.site-footer {
		background: var(--footer-bg);
		border-top: 2px solid var(--border);
	}

	.footer-top {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
		border-bottom: 1px solid rgba(0, 0, 244, 0.15);
	}

	.footer-col {
		padding: 2rem 1.75rem;
		border-right: 1px solid rgba(0, 0, 244, 0.1);
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.footer-col:last-child {
		border-right: none;
	}

	.footer-brand {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		min-height: 34px;
	}

	.footer-brand-icon {
		width: 34px;
		height: 34px;
		object-fit: contain;
		filter: drop-shadow(0 0 10px rgba(95, 125, 255, 0.35));
	}

	.footer-wordmark {
		display: inline-flex;
		align-items: center;
		font-family: 'Courier New', monospace;
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		color: var(--primary);
		line-height: 1;
	}

	.footer-word-char {
		display: inline-block;
		min-width: 0.63ch;
		will-change: transform, opacity, text-shadow;
	}

	.footer-tagline {
		font-family: 'Poppins', sans-serif;
		font-size: 0.65rem;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.7;
	}

	.footer-heading {
		font-family: 'Poppins', sans-serif;
		font-size: 0.62rem;
		letter-spacing: 0.22em;
		color: var(--primary);
		margin: 0 0 0.4rem;
	}

	.footer-link {
		font-family: 'Poppins', sans-serif;
		font-size: 0.85rem;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.1s;
	}

	.footer-link:hover {
		color: var(--text);
	}

	.footer-none {
		font-family: 'Poppins', sans-serif;
		color: var(--text-muted);
		opacity: 0.4;
		margin: 0;
	}

	.footer-bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 1.75rem;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.footer-copy {
		font-family: 'Poppins', sans-serif;
		font-size: 0.58rem;
		letter-spacing: 0.25em;
		color: var(--text-muted);
		opacity: 0.5;
	}

	.footer-heart-wrap {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.footer-made {
		font-family: 'Poppins', sans-serif;
		font-size: 0.58rem;
		letter-spacing: 0.2em;
		color: var(--text-muted);
		opacity: 0.5;
	}

	.heart-btn {
		background: none;
		border: none;
		cursor: pointer;
		color: var(--accent);
		padding: 2px;
		line-height: 1;
	}

	#heart-svg {
		transition: transform 0.12s ease;
		display: block;
	}

	@media (max-width: 520px) {
		.footer-wordmark {
			font-size: 0.66rem;
			letter-spacing: 0.09em;
		}
	}
</style>
